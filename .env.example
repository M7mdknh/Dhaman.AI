# ---- Decision Intelligence (Sprint 4) — ALL OPTIONAL.
# Without an API key the app automatically uses the deterministic
# MockProvider and remains fully deployable.
# OPENAI_API_KEY=""
# Chat model used by the OpenAI provider (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"
# Force a provider regardless of key presence: "openai" | "mock"
# LLM_PROVIDER="mock"
# Per-request timeout for the LLM call in milliseconds (default: 45000)
# LLM_TIMEOUT_MS="45000"
