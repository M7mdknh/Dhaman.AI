DATABASE_URL="postgresql://daman:daman_dev@localhost:5432/daman"
# 32+ random bytes; generate with: openssl rand -base64 32
SESSION_SECRET=""
# Root directory for uploaded case documents (local disk adapter).
# Used only for local development — ignored when S3_BUCKET is set below.
UPLOAD_DIR="uploads"

# ---- Document storage (S3-compatible object store).
# REQUIRED in production: Vercel's filesystem is read-only, so the local-disk
# adapter above cannot persist uploads there. When S3_BUCKET is unset the app
# uses local disk (development only). The bucket MUST be private — documents
# are streamed through the access-checked download route, never linked directly.
# Works with AWS S3, Cloudflare R2, and MinIO.
# S3_BUCKET="daman-documents"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# Custom endpoint for non-AWS providers (e.g. Cloudflare R2); omit for AWS S3.
# S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
# Path-style addressing: "true" for MinIO/some R2 setups, "false" for AWS.
# S3_FORCE_PATH_STYLE="false"

# ---- Decision Intelligence (Sprint 4) — ALL OPTIONAL.
# Without an API key the app automatically uses the deterministic
# MockProvider and remains fully deployable.
# OPENAI_API_KEY=""
# Chat model used by the OpenAI provider (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"
# Force a provider regardless of key presence: "openai" | "mock"
# LLM_PROVIDER="mock"
# Per-request timeout for the LLM call in milliseconds (default: 45000)
# LLM_TIMEOUT_MS="45000"

# ---- OCR (tesseract.js) — ALL OPTIONAL.
# The WASM core resolves from node_modules; only the language traineddata is
# fetched, by default from a public CDN. To remove that runtime CDN dependency,
# point TESSERACT_LANG_PATH at a directory/URL hosting ara.traineddata.gz and
# eng.traineddata.gz. TESSERACT_CACHE_PATH must be writable (on Vercel the only
# writable dir is /tmp) — the default already targets it.
# TESSERACT_LANG_PATH="https://tessdata.projectnaptha.com/4.0.0"
# TESSERACT_CORE_PATH=""
# TESSERACT_CACHE_PATH="/tmp/tessdata"
#
# OCR speed/quality knobs (the MVP optimizes for speed). Only statement pages
# are ever OCR'd, in parallel across a worker pool. OCR_CONCURRENCY = parallel
# tesseract workers (each holds the ara+eng models in memory — raise only with
# RAM headroom). OCR_DPI trades legibility for speed (OCR numerics are low-trust
# and gated regardless). OCR_MAX_PAGES caps pages OCR'd per document.
# OCR_CONCURRENCY="2"
# OCR_DPI="200"
# OCR_MAX_PAGES="10"
