// Daman — initial schema (Sprint 0).
// Financial analysis is deliberately NOT persisted (decision 2026-07-06):
// it is computed on demand from FinancialStatement rows — see
// docs/FINANCIAL_ENGINE.md. The Sprint 4 DecisionIntelligence rows freeze
// the exact engine snapshot a memo explained (docs/DECISION_INTELLIGENCE.md).
// Sprint 5 adds the officer workspace records: OfficerDecision, CaseNote,
// Guarantee (docs/UNDERWRITING_WORKSPACE.md).
// Deliberately absent: Open Banking / SIMAH (Future — never tables, only
// provider interfaces).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CONTRACTOR
  // Reviews the AI-drafted memo, adds relationship context, and routes the
  // package to the Risk Officer (framework step 8). Never decides.
  RELATIONSHIP_MANAGER
  RISK_OFFICER
  ADMIN
}

// Full case lifecycle vocabulary from day one (avoids enum migration churn).
// A case is SAVED at SUBMITTED and immediately enters PROCESSING; the async
// financial-processing pipeline (CaseProcessing) then drives it to
// ANALYSIS_READY on success or PROCESSING_FAILED on failure — the case row is
// never lost either way. PARSING is the legacy pre-async marker, kept only so
// the enum stays additive.
enum CaseStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  PROCESSING_FAILED
  PARSING
  ANALYSIS_READY
  // The RM reviewed the AI draft and routed the package to the Risk Officer.
  // The officer can also start directly from ANALYSIS_READY (RM step is a
  // quality pass, never a bottleneck).
  RM_REVIEWED
  UNDER_REVIEW
  INFO_REQUESTED
  APPROVED
  DECLINED
  ISSUED
}

// Ordered stages of the async financial-processing pipeline. Surfaced live on
// the case page as the processing dashboard.
enum ProcessingStage {
  READING_STATEMENTS
  DETECTING_STATEMENTS
  EXTRACTING_DATA
  FINANCIAL_ANALYSIS
  AI_UNDERWRITING
}

// Lifecycle of a case's processing job (durable, retryable — independent of
// the submission request that created it).
enum ProcessingState {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum GuaranteeType {
  BID_BOND
  PERFORMANCE
  ADVANCE_PAYMENT
  RETENTION
  LETTER_OF_CREDIT
}

enum BeneficiaryType {
  GOVERNMENT
  PRIVATE
}

enum DocumentType {
  FINANCIAL_STATEMENT
  CONTRACT
  OTHER
}

// Reliability of an uploaded statement: audited > reviewed > management
// accounts. Drives the confidence weighting on the financial pillar —
// never the score itself (uncertainty must not read as risk OR safety).
enum StatementType {
  AUDITED
  REVIEWED
  MANAGEMENT
}

// Saudization compliance band (Nitaqat). RED can freeze work visas and
// stall a labor-dependent project mid-execution — scored AND hard-capped.
enum NitaqatBand {
  PLATINUM
  GREEN
  YELLOW
  RED
}

// Track-record depth band (KYC 1B).
enum ProjectsCompletedBand {
  UNDER_5
  FROM_5_TO_10
  FROM_10_TO_25
  OVER_25
}

// How the equipment for the guaranteed project is sourced (KYC 1C).
enum EquipmentPlan {
  OWNED
  RENT
  PURCHASE
}

// Who audits the applicant's financials (KYC 1D) — governs how much the
// ratio engine's inputs can be trusted.
enum AuditorTier {
  BIG_FOUR
  ACCREDITED_LOCAL
  OTHER_FIRM
  UNAUDITED
}

// How the project is funded until the first payment certificate (KYC 1D).
enum FundingSource {
  OWN_CASH
  THIS_BANK
  OTHER_BANK
  SUPPLIER_CREDIT
}

// The applicant's role in the guaranteed contract (Step 3, 2A).
enum ContractorRole {
  MAIN_CONTRACTOR
  SUBCONTRACTOR
}

// How the contract was won (Step 3, 2A). Public tenders are won on price —
// interacts with the declared-margin factors.
enum AwardMethod {
  PUBLIC_TENDER
  LIMITED_TENDER
  DIRECT_AWARD
}

// Progress billing cadence (Step 3, 2B) — frequency of project cash inflows.
enum BillingCycle {
  MONTHLY
  MILESTONE
  OTHER
}

// Lifecycle of the IFRS extraction pipeline for one uploaded document.
enum DocumentProcessingStatus {
  UPLOADED
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  // Express underwriting reads only the LATEST audited statement; older
  // uploads are marked SKIPPED (an explicit, honest state — never an
  // eternally-"Queued" document the user wonders about).
  SKIPPED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String   @map("full_name")
  passwordHash String   @map("password_hash")
  role         UserRole
  // A contractor user belongs to their company (Company 1 → N Users).
  // Nullable: bank staff (RISK_OFFICER, ADMIN) have no company.
  companyId    String?  @map("company_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company            Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  cases              UnderwritingCase[]
  documents          Document[]
  auditLogs          AuditLog[]
  decisionsRequested DecisionIntelligence[]
  assignedCases      UnderwritingCase[]     @relation("AssignedOfficer")
  rmReviewedCases    UnderwritingCase[]     @relation("RmReviewer")
  officerDecisions   OfficerDecision[]
  rmSuggestedDecisions RmSuggestedDecision[]
  caseNotes          CaseNote[]
  memoRevisions      MemoRevision[]
  guaranteesIssued   Guarantee[]

  @@index([companyId])
  @@map("users")
}

model Company {
  id            String   @id @default(cuid())
  name          String
  crNumber      String   @unique @map("cr_number")
  sector        String
  city          String
  // Contact block shown in wizard Step 1; nullable because seeded/legacy
  // companies predate these fields.
  contactPerson String?  @map("contact_person")
  contactEmail  String?  @map("contact_email")
  phone         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  users User[]
  cases UnderwritingCase[]

  @@index([name])
  @@map("companies")
}

model UnderwritingCase {
  id          String     @id @default(cuid())
  // Internal race-free counter. NEVER displayed — the application-layer case
  // service formats the human-readable `reference` from it at creation.
  seq         Int        @default(autoincrement()) @unique
  // Human-readable case number, e.g. UC-2026-000001 (assigned by the case service).
  reference   String     @unique
  companyId   String     @map("company_id")
  createdById String     @map("created_by_id")
  status      CaseStatus @default(DRAFT)
  submittedAt DateTime?  @map("submitted_at")
  // Officer review lifecycle (Sprint 5). The first officer to start the
  // review claims the case; decidedAt marks the latest terminal decision.
  assignedOfficerId String?   @map("assigned_officer_id")
  reviewStartedAt   DateTime? @map("review_started_at")
  decidedAt         DateTime? @map("decided_at")
  // RM review stage (framework step 8): who routed the package to the Risk
  // Officer and when. Null while the RM step is pending or was bypassed.
  rmReviewerId  String?   @map("rm_reviewer_id")
  rmSubmittedAt DateTime? @map("rm_submitted_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  company              Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy            User                   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  assignedOfficer      User?                  @relation("AssignedOfficer", fields: [assignedOfficerId], references: [id], onDelete: SetNull)
  rmReviewer           User?                  @relation("RmReviewer", fields: [rmReviewerId], references: [id], onDelete: SetNull)
  contractDetails      ContractDetails?
  qualitative          CaseQualitative?
  documents            Document[]
  financialStatements  FinancialStatement[]
  auditLogs            AuditLog[]
  decisionIntelligence DecisionIntelligence[]
  officerDecisions     OfficerDecision[]
  rmSuggestedDecisions RmSuggestedDecision[]
  notes                CaseNote[]
  memoRevisions        MemoRevision[]
  guarantee            Guarantee?
  processing           CaseProcessing?

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@index([assignedOfficerId])
  @@map("underwriting_cases")
}

// Per-case KYC questionnaire (wizard Step 2) — the qualitative side of the
// underwriting grade. Deliberately 1:1 with the CASE, not the company:
// every decision permanently keeps the exact answers it was made under
// (same principle as the company identity lock), and answers that drift
// between a company's cases are themselves a signal the officer can see.
// Scores are NEVER persisted — the qualitative pillar is computed on demand
// from this row by qualitative-score-service (same rule as the ratios).
model CaseQualitative {
  id     String @id @default(cuid())
  caseId String @unique @map("case_id")

  // ---- 1A. Company profile
  // CR issuance date — operating age is DERIVED from it (never self-banded).
  crIssueDate DateTime @map("cr_issue_date") @db.Date
  // Registered CR activities (free text from the certificate) — feeds the
  // scope-vs-capability check against the contract sector.
  crActivities             String  @map("cr_activities")
  // Contractor classification (Momtaz / 1–5), when the applicant holds one.
  contractorClassification String? @map("contractor_classification")
  partOfGroup              Boolean @map("part_of_group")
  groupName                String? @map("group_name")
  gmName                   String  @map("gm_name")
  gmExperienceYears        Int     @map("gm_experience_years")
  // Ownership or management change in the last 2 years — invalidates the
  // track record earned before it.
  ownershipChanged     Boolean     @map("ownership_changed")
  ownershipChangeNote  String?     @map("ownership_change_note")
  nitaqatBand          NitaqatBand @map("nitaqat_band")
  ongoingLitigation    Boolean     @map("ongoing_litigation")
  litigationNote       String?     @map("litigation_note")

  // ---- 1B. Track record & experience
  projectsCompletedBand ProjectsCompletedBand @map("projects_completed_band")
  // Largest single completed project — the jump-risk denominator.
  largestProjectValue Decimal @map("largest_project_value") @db.Decimal(18, 2)
  // Any project terminated / withdrawn / hit by major delay or penalty.
  hadProjectIssues  Boolean @map("had_project_issues")
  projectIssuesNote String? @map("project_issues_note")
  // The strongest negative signal for a guarantee product — hard cap.
  guaranteeCalled     Boolean @map("guarantee_called")
  guaranteeCalledNote String? @map("guarantee_called_note")
  sameTypeExperience     Boolean @map("same_type_experience")
  sameTypeExperienceNote String? @map("same_type_experience_note")

  // ---- 1C. Current workload & capacity
  runningProjectsCount Int     @map("running_projects_count")
  // Combined remaining (unbilled) value of running projects.
  backlogValue Decimal @map("backlog_value") @db.Decimal(18, 2)
  // Self-declared outstanding guarantees across ALL banks (no SIMAH
  // cross-check in this phase — declaration only).
  outstandingGuarantees Decimal       @map("outstanding_guarantees") @db.Decimal(18, 2)
  equipmentPlan         EquipmentPlan @map("equipment_plan")
  heavyHiringNeeded     Boolean       @map("heavy_hiring_needed")

  // ---- 1D. Financial conduct
  mainBank String @map("main_bank")
  // Bounced cheques / past dues / restructured facilities — declared. Any
  // "yes" is a hard cap; a clean declaration earns the conduct points.
  conductIncidents     Boolean       @map("conduct_incidents")
  conductIncidentsNote String?       @map("conduct_incidents_note")
  auditorTier          AuditorTier   @map("auditor_tier")
  auditorName          String?       @map("auditor_name")
  fundingSource        FundingSource @map("funding_source")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  case UnderwritingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_qualitatives")
}

model ContractDetails {
  id                   String          @id @default(cuid())
  caseId               String          @unique @map("case_id")
  beneficiary          String
  beneficiaryType      BeneficiaryType @map("beneficiary_type")
  contractTitle        String          @map("contract_title")
  contractDescription  String?         @map("contract_description")
  sector               String
  projectLocation      String          @map("project_location")
  contractValue        Decimal         @map("contract_value") @db.Decimal(18, 2)
  currency             String          @default("SAR")
  // Derived (never entered directly): contractValue * guaranteePercentage / 100.
  // See saveContractDetails (case-service.ts) — the ratio is the single
  // source of truth for exposure size.
  guaranteeAmount      Decimal         @map("guarantee_amount") @db.Decimal(18, 2)
  guaranteeType        GuaranteeType   @map("guarantee_type")
  // % of contract value the guarantee covers (0–100). Required: this is now
  // the applicant's actual input; guaranteeAmount is derived from it.
  guaranteePercentage  Decimal         @map("guarantee_percentage") @db.Decimal(5, 2)
  projectStartDate     DateTime        @map("project_start_date") @db.Date
  projectEndDate       DateTime        @map("project_end_date") @db.Date
  // Legacy free-text payment terms — superseded by the structured payment
  // fields below; kept nullable so pre-existing cases still display.
  expectedPaymentTerms String?         @map("expected_payment_terms")
  additionalNotes      String?         @map("additional_notes")

  // ---- 2A. Contractor role (nullable: cases predating the detailed form).
  contractorRole     ContractorRole? @map("contractor_role")
  mainContractorName String?         @map("main_contractor_name")
  // Subcontractor paid only when the main contractor is paid.
  backToBackPayment Boolean?     @map("back_to_back_payment")
  awardMethod       AwardMethod? @map("award_method")
  // Prior contracts completed with this awarding entity (0 = first time).
  priorContractsWithBeneficiary Int? @map("prior_contracts_with_beneficiary")

  // ---- 2B. Payment mechanics (replaces the free-text terms).
  advancePaymentPct Decimal?      @map("advance_payment_pct") @db.Decimal(5, 2)
  billingCycle      BillingCycle? @map("billing_cycle")
  retentionPct      Decimal?      @map("retention_pct") @db.Decimal(5, 2)
  // Days from invoice certification to payment (30/60/90/120).
  paymentPeriodDays Int? @map("payment_period_days")
  // Anything unusual about the payment arrangement (optional notes).
  paymentNotes String? @map("payment_notes")

  // ---- 2C. Bond requirements per the contract text.
  requiredBondPct  Decimal?  @map("required_bond_pct") @db.Decimal(5, 2)
  bondValidityDate DateTime? @map("bond_validity_date") @db.Date
  onFirstDemand    Boolean?  @map("on_first_demand")
  extendOrPay      Boolean?  @map("extend_or_pay")

  // ---- 2D. Penalty clauses.
  // Liquidated damages for delay, % of contract value per week.
  ldRatePctPerWeek Decimal? @map("ld_rate_pct_per_week") @db.Decimal(5, 2)
  ldCapPct         Decimal? @map("ld_cap_pct") @db.Decimal(5, 2)

  // ---- 2E. Execution plan. (Expected first invoice date is DERIVED from
  // start date + mobilization + billing cycle + payment period — never asked.)
  mobilizationWeeks      Int?     @map("mobilization_weeks")
  keySuppliersIdentified Boolean? @map("key_suppliers_identified")
  keySuppliersNote       String?  @map("key_suppliers_note")
  expectedGrossMarginPct Decimal? @map("expected_gross_margin_pct") @db.Decimal(5, 2)

  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  case UnderwritingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("contract_details")
}

model Document {
  id           String       @id @default(cuid())
  caseId       String       @map("case_id")
  uploadedById String?      @map("uploaded_by_id")
  // Original client filename — display metadata ONLY, never used as a path.
  fileName     String       @map("file_name")
  // Server-generated object key inside the storage adapter.
  storageKey   String       @unique @map("storage_key")
  mimeType     String       @map("mime_type")
  fileSize     Int          @map("file_size")
  docType      DocumentType @default(FINANCIAL_STATEMENT) @map("doc_type")
  // Fiscal year the statement covers (financial statements only).
  fiscalYear   Int?         @map("fiscal_year")
  // Reliability class declared at upload (financial statements only) —
  // audited / reviewed / management accounts.
  statementType StatementType? @map("statement_type")
  // IFRS pipeline status; set to QUEUED at case submission.
  processingStatus DocumentProcessingStatus @default(UPLOADED) @map("processing_status")
  // Live per-stage execution log of THIS document's current processing run:
  // [{ stage, startedAt, note? }] appended as the document moves through its
  // own lifecycle (Preparing → Reading → Detecting → Extracting → terminal).
  // Drives the per-document rows of the live processing dashboard.
  processingEvents Json? @map("processing_events")
  // Content hash, computed at processing time — used for duplicate detection.
  sha256       String?
  createdAt    DateTime     @default(now()) @map("created_at")

  case                UnderwritingCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy          User?                @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  financialStatements FinancialStatement[]
  extraction          DocumentExtraction?

  @@index([caseId])
  @@map("documents")
}

// Latest extraction run for a document (raw output + provenance).
// Only the most recent run is kept: the unique on documentId enforces it.
// Parser versioning later = add a parserVersion column and widen the unique
// to (documentId, parserVersion) — no structural refactor needed.
model DocumentExtraction {
  id          String    @id @default(cuid())
  documentId  String    @unique @map("document_id")
  parserName  String    @map("parser_name")
  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")

  currency           String?
  // Multiplier the source used ("SAR '000" → 1000); normalized values are absolute.
  scale              Int      @default(1)
  fiscalYears        Int[]    @map("fiscal_years")
  detectedStatements String[] @map("detected_statements")
  companyName        String?  @map("company_name")

  // Full raw pipeline output: line items with original label/value AND
  // normalized key/value, per statement. Never post-processed.
  raw        Json?
  // Validation outcome: { errors: [...], warnings: [...] }.
  validation Json?
  // Terminal failure reason (user-facing message).
  error      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_extractions")
}

// One row per parsed fiscal year (populated by the Sprint 4 IFRS parser).
// Canonical figures are typed Decimal columns so they are queryable and
// precise; raw parser output/provenance lives in sourceJson.
model FinancialStatement {
  id         String  @id @default(cuid())
  caseId     String  @map("case_id")
  documentId String? @map("document_id")
  fiscalYear Int     @map("fiscal_year")
  currency   String  @default("SAR")
  // Kept in sync with statementType (audited = AUDITED) for legacy readers.
  audited    Boolean @default(true)
  // Reliability class, carried from the source document's upload declaration.
  // Weights the officer's confidence in the financial pillar — never the score.
  statementType StatementType @default(AUDITED) @map("statement_type")

  revenue            Decimal? @db.Decimal(18, 2)
  cogs               Decimal? @db.Decimal(18, 2)
  grossProfit        Decimal? @map("gross_profit") @db.Decimal(18, 2)
  operatingIncome    Decimal? @map("operating_income") @db.Decimal(18, 2)
  netIncome          Decimal? @map("net_income") @db.Decimal(18, 2)
  ebitda             Decimal? @db.Decimal(18, 2)
  // Depreciation & amortization add-back (from the cash flow reconciliation).
  // Used to derive EBITDA (operatingIncome + D&A) when a statement never
  // prints an "EBITDA" line itself — the common case, since EBITDA is a
  // non-IFRS metric. See financial-ratio-service.ts:derivedEbitda.
  depreciationAmortization Decimal? @map("depreciation_amortization") @db.Decimal(18, 2)
  interestExpense    Decimal? @map("interest_expense") @db.Decimal(18, 2)
  cash               Decimal? @db.Decimal(18, 2)
  receivables        Decimal? @db.Decimal(18, 2)
  inventory          Decimal? @db.Decimal(18, 2)
  currentAssets      Decimal? @map("current_assets") @db.Decimal(18, 2)
  totalAssets        Decimal? @map("total_assets") @db.Decimal(18, 2)
  currentLiabilities Decimal? @map("current_liabilities") @db.Decimal(18, 2)
  totalLiabilities   Decimal? @map("total_liabilities") @db.Decimal(18, 2)
  shortTermDebt      Decimal? @map("short_term_debt") @db.Decimal(18, 2)
  longTermDebt       Decimal? @map("long_term_debt") @db.Decimal(18, 2)
  totalDebt          Decimal? @map("total_debt") @db.Decimal(18, 2)
  totalEquity        Decimal? @map("total_equity") @db.Decimal(18, 2)
  operatingCashFlow  Decimal? @map("operating_cash_flow") @db.Decimal(18, 2)
  investingCashFlow  Decimal? @map("investing_cash_flow") @db.Decimal(18, 2)
  financingCashFlow  Decimal? @map("financing_cash_flow") @db.Decimal(18, 2)
  capex              Decimal? @db.Decimal(18, 2)
  annualDebtService  Decimal? @map("annual_debt_service") @db.Decimal(18, 2)

  sourceJson Json?    @map("source_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  case UnderwritingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  // Provenance: which upload these figures were parsed from. SetNull so the
  // parsed evidence outlives removal of the source document row.
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([caseId, fiscalYear])
  @@map("financial_statements")
}

// Bank policy's recommendation vocabulary. The recommendation OF RECORD is
// always derived deterministically from the risk band (thresholds.ts) —
// the model must echo it and explain it, never choose it.
enum RecommendationType {
  APPROVE
  APPROVE_WITH_CONDITIONS
  MANUAL_REVIEW
  REJECT
}

// One AI underwriting memo run (Sprint 4 Decision Intelligence).
// Append-only: regeneration adds a row; the newest row is the active memo.
// Only VALIDATED responses are persisted — failures live in the audit log.
model DecisionIntelligence {
  id     String @id @default(cuid())
  caseId String @map("case_id")
  // Who requested the generation (SetNull: memo survives user removal).
  requestedById String? @map("requested_by_id")

  // ---- Provenance: exactly what the model saw and how it was called.
  // Frozen structured input (the immutable analysis snapshot the memo
  // explains). Never rebuilt from live rows.
  inputSnapshot Json   @map("input_snapshot")
  // sha256 over (canonical input + prompt version + provider + model) —
  // the response cache key: identical inputs never trigger a repeat call.
  inputHash     String @map("input_hash")
  provider      String
  model         String
  promptVersion String @map("prompt_version")
  latencyMs     Int?   @map("latency_ms")

  // ---- Validated memo (zod-checked before persistence).
  summary               String
  companyStrengths      String[] @map("company_strengths")
  companyWeaknesses     String[] @map("company_weaknesses")
  contractAssessment    String   @map("contract_assessment")
  riskExplanation       String   @map("risk_explanation")
  recommendationReason  String   @map("recommendation_reason")
  missingInformation    String[] @map("missing_information")
  confidenceExplanation String   @map("confidence_explanation")
  nextSteps             String[] @map("next_steps")

  // ---- Recommendation of record: deterministic bank policy (risk band →
  // recommendation). aiRecommendation is what the model returned; when it
  // diverges, policy wins and the divergence is flagged for the officer.
  recommendation   RecommendationType @map("recommendation")
  aiRecommendation RecommendationType @map("ai_recommendation")
  aiDiverged       Boolean            @default(false) @map("ai_diverged")

  createdAt DateTime @default(now()) @map("created_at")

  case                 UnderwritingCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  requestedBy          User?                 @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  officerDecisions     OfficerDecision[]
  rmSuggestedDecisions RmSuggestedDecision[]
  memoRevisions        MemoRevision[]

  @@index([caseId, createdAt])
  @@index([caseId, inputHash])
  @@map("decision_intelligence")
}

// The Risk Officer's decision vocabulary (Sprint 5). "Manual Review" is
// deliberately NOT a decision — the officer in the workspace IS the manual
// review; it exists only as an AI recommendation value.
enum OfficerDecisionType {
  APPROVE
  APPROVE_WITH_CONDITIONS
  REJECT
  REQUEST_INFO
}

// One officer decision event. Append-only: a REQUEST_INFO can be followed by
// a terminal decision; the newest row is the decision of record.
model OfficerDecision {
  id        String              @id @default(cuid())
  caseId    String              @map("case_id")
  officerId String              @map("officer_id")
  decision  OfficerDecisionType
  // Mandatory internal reasoning. Only REQUEST_INFO content is ever shown to
  // the contractor; approve/reject reasoning stays bank-internal.
  reason     String
  // Conditions attached to APPROVE_WITH_CONDITIONS (null otherwise).
  conditions String?
  // Which AI memo the officer had in front of them (SetNull: the decision
  // record outlives memo housekeeping).
  decisionIntelligenceId String?  @map("decision_intelligence_id")
  createdAt              DateTime @default(now()) @map("created_at")

  case                 UnderwritingCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  officer              User                  @relation(fields: [officerId], references: [id], onDelete: Restrict)
  decisionIntelligence DecisionIntelligence? @relation(fields: [decisionIntelligenceId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@map("officer_decisions")
}

// The RM's suggested decision (framework step 8, extended): recorded exactly
// once, alongside routing the package to the Risk Officer (canRmSubmit is a
// one-time transition from ANALYSIS_READY). Uses the same vocabulary as
// OfficerDecisionType so the officer's screen can show it as a starting
// point — the RM never decides; this is a recommendation the officer may
// accept or override. Separate table from OfficerDecision so "decision of
// record" queries (guarantee issuance, contractor-visible status) can never
// confuse a suggestion with an actual decision.
model RmSuggestedDecision {
  id        String              @id @default(cuid())
  caseId    String              @map("case_id")
  rmId      String              @map("rm_id")
  decision  OfficerDecisionType
  reason     String
  // Conditions attached to APPROVE_WITH_CONDITIONS (null otherwise).
  conditions String?
  // Which AI memo the RM had in front of them (SetNull: the record outlives
  // memo housekeeping).
  decisionIntelligenceId String?  @map("decision_intelligence_id")
  createdAt              DateTime @default(now()) @map("created_at")

  case                 UnderwritingCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  rm                   User                  @relation(fields: [rmId], references: [id], onDelete: Restrict)
  decisionIntelligence DecisionIntelligence? @relation(fields: [decisionIntelligenceId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@map("rm_suggested_decisions")
}

// RM refinement of the AI-drafted memo (framework step 8: the RM reviews the
// draft, edits or supplements it with relationship insight, and submits it
// onward — every change is version-tracked). Append-only: each save adds a
// numbered version and the newest row is the RM assessment of record. The AI
// original in DecisionIntelligence is NEVER mutated — provenance stays intact.
model MemoRevision {
  id     String @id @default(cuid())
  caseId String @map("case_id")
  // Which AI memo this revision refines (SetNull: the revision record
  // outlives memo housekeeping).
  decisionIntelligenceId String? @map("decision_intelligence_id")
  authorId               String? @map("author_id")
  // 1-based, unique per case — the version trail the framework requires.
  version Int
  // RM-refined executive summary (starts from the AI draft).
  summary String
  // Relationship context the RM adds — the human insight the AI cannot know.
  relationshipContext String? @map("relationship_context")
  createdAt           DateTime @default(now()) @map("created_at")

  case                 UnderwritingCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  decisionIntelligence DecisionIntelligence? @relation(fields: [decisionIntelligenceId], references: [id], onDelete: SetNull)
  author               User?                 @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([caseId, version])
  @@index([caseId, createdAt])
  @@map("memo_revisions")
}

// Internal officer note on a case. NEVER exposed through any
// contractor-facing query or serialization.
model CaseNote {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  authorId  String?  @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  case   UnderwritingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@map("case_notes")
}

// The async financial-processing job for a case (1:1). Created QUEUED at
// submission and driven by the processing orchestrator — completely
// independent of the request that submitted the case. It is the durable
// record that makes processing observable (live dashboard) and retryable:
// a failure sets `state=FAILED` + `error`/`failedStage`, the case row stays
// intact, and a retry re-runs the pipeline on the SAME uploaded documents.
model CaseProcessing {
  id     String @id @default(cuid())
  caseId String @unique @map("case_id")

  state ProcessingState @default(QUEUED)
  // The stage currently running, last completed on success, or the one that
  // failed. Interpreted against `state` to render the live dashboard.
  stage       ProcessingStage?
  // The stage a FAILED run died in (null while queued/running/completed).
  failedStage ProcessingStage? @map("failed_stage")
  // Number of runs attempted (a retry increments this). Powers "attempt N".
  attempts    Int              @default(0)
  // User-facing failure reason on a FAILED run (never a raw stack trace).
  error       String?
  // Live per-stage execution log for the current run:
  // [{ stage, startedAt, note? }] appended as each stage begins. Durations are
  // derived (a stage ends when the next begins / the run completes). Reset on
  // every (re)queue so it always describes the run in progress.
  stageEvents Json?            @map("stage_events")

  queuedAt    DateTime  @default(now()) @map("queued_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  case UnderwritingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([state])
  @@map("case_processing")
}

// Issued Letter of Guarantee (Sprint 5). One per case; the PDF is rendered
// on demand from this row (deterministic) — nothing is stored on disk.
model Guarantee {
  id     String @id @default(cuid())
  // Internal race-free counter for minting the human reference (never shown).
  seq    Int    @default(autoincrement()) @unique
  // Human-readable guarantee number, e.g. LG-2026-000001.
  reference  String   @unique
  caseId     String   @unique @map("case_id")
  issuedById String   @map("issued_by_id")
  amount     Decimal  @db.Decimal(18, 2)
  currency   String   @default("SAR")
  beneficiary String
  issueDate  DateTime @map("issue_date") @db.Date
  // Follows the guaranteed contract's end date.
  expiryDate DateTime @map("expiry_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  // Restrict on both: an issued bank instrument must never disappear
  // because a case or user row was removed.
  case     UnderwritingCase @relation(fields: [caseId], references: [id], onDelete: Restrict)
  issuedBy User             @relation(fields: [issuedById], references: [id], onDelete: Restrict)

  @@map("guarantees")
}

// Append-only. No service exposes update or delete for this table.
// Case/actor links are SetNull so audit history survives entity removal.
model AuditLog {
  id        String   @id @default(cuid())
  caseId    String?  @map("case_id")
  actorId   String?  @map("actor_id")
  action    String
  detail    Json?
  createdAt DateTime @default(now()) @map("created_at")

  case  UnderwritingCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  actor User?             @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([createdAt])
  @@map("audit_logs")
}
